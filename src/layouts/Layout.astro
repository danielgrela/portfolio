---
import '../styles/global.css';
---
<!doctype html>
<html lang="en" class="scroll-smooth min-h-dvh md:h-dvh bg-linear-to-tl from-gray-50 to-gray-150 dark:from-gray-950 dark:to-gray-900 ">
    <head>
        <script is:inline>
            //Detectar tema del navegador
            if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark')
            }
        </script>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>Daniel Grela</title>
    </head>
    <body class="min-h-dvh md:h-dvh flex flex-col items-center justify-center text-center md:text-start text-black dark:text-white">
        <slot />
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
    }
</style>