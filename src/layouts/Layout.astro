---
import { getLangFromUrl } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import '../styles/global.css';
---
<!doctype html>
<html lang={lang} class="scroll-smooth min-h-dvh md:h-dvh bg-linear-to-tl from-gray-50 to-gray-150 dark:to-black dark:from-gray-950 ">
    <head>
        <script is:inline>
            //Detectar tema del navegador
            if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark')
            }
        </script>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png">
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" sizes="any">
        <link rel="icon" href="/favicon.ico">
        <link rel="apple-touch-icon" href="/apple-touch-icon.png">
        <meta name="generator" content={Astro.generator} />
        <title>Daniel Grela</title>
    </head>
    <body class="px-4 md:px-12  min-h-dvh md:h-dvh flex flex-col items-center justify-center text-center md:text-start text-heading">
        <slot />
        <div class="absolute top-8 right-8 md:top-auto md:right-auto md:bottom-8 md:left-12">
            <LanguageSwitcher />
        </div>
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
    }
</style>