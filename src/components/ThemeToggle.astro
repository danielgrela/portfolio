---
import type { HTMLAttributes } from 'astro/types'

type Props = HTMLAttributes<'div'> & {
  duration?: number
}

const { duration = 750, ...rest } = Astro.props
---

<astro-theme-toggle {...rest} data-duration={duration}>
  <div class="astro-theme-toggle-icon-light">
    <slot name="icon-light" />
  </div>
  <div class="astro-theme-toggle-icon-dark">
    <slot name="icon-dark" />
  </div>
</astro-theme-toggle>

<script>
  import { handleThemeToggleClick } from '../scripts/handle-theme-toggle-click'

  class AstroThemeToggle extends HTMLElement {
    connectedCallback() {
      if (!this.hasAttribute('tabindex')) {
        this.setAttribute('tabindex', '0')
      }
      if (!this.hasAttribute('role')) {
        this.setAttribute('role', 'button')
      }
      this.addEventListener('click', handleThemeToggleClick)
      this.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault()
          const rect = this.getBoundingClientRect()
          const clientX = rect.left + rect.width / 2
          const clientY = rect.top + rect.height / 2
          handleThemeToggleClick({ clientX, clientY, currentTarget: this })
        }
      })
    }
  }

  if (!customElements.get('astro-theme-toggle')) {
    customElements.define('astro-theme-toggle', AstroThemeToggle)
  }
</script>

<style is:global>
  astro-theme-toggle {
    display: block;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .astro-theme-toggle-icon-light,
  .astro-theme-toggle-icon-dark {
    width: 100%;
    height: 100%;

    & * {
      display: block;
    }
  }

  .astro-theme-toggle-icon-light {
    display: block;

    .dark & {
      display: none;
    }
  }

  .astro-theme-toggle-icon-dark {
    display: none;

    .dark & {
      display: block;
    }
  }
</style>
