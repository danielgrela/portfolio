---
import { Image } from "astro:assets";
import { getLangFromUrl } from "../../i18n/utils";

const {title, description, date, link , src} = Astro.props;

const lang = getLangFromUrl(Astro.url);

let proyectoHref = link;

if (!link.startsWith('/')) {
  proyectoHref = `/${lang}/${link}`;
} else {
  proyectoHref = `/${lang}${link}`;
}

interface ProyectoCardProps {
    src: string;
    title: string;
    description: string;
    date: string;
    link: string;
}
---
<li class="w-full hidden md:block">
    <a href={proyectoHref} class="w-full flex flex-col gap-2 transition-all duration-200 rounded-lg 
    hover:p-4 hover:bg-gray-200 dark:hover:bg-gray-800">
        <Image src={src} alt="Imagen del proyecto" class="w-full h-auto rounded-md" />  
        <div class="flex flex-row gap-4 items-center text-center justify-between">
            <h3 class="text-xl font-semibold text-start w-2/3">{title}</h3>
            {date && <span class="text-sm text-body">{date}</span>}
        </div>
        <p class="text-body">{description}</p>
    </a>
</li>
<li class="w-full block md:hidden">
    <a href={proyectoHref} class="w-full flex flex-col gap-2 transition-all duration-200 rounded-lg 
    border-2 border-default-medium p-4 bg-gray-100 dark:bg-gray-900">
        <Image src={src} alt="Imagen del proyecto" class="w-full h-auto rounded-md" />  
        <div class="flex flex-row gap-4 items-center text-center justify-between">
            <h3 class="text-xl font-semibold text-start w-2/3">{title}</h3>
            {date && <span class="text-sm text-body">{date}</span>}
        </div>
        <p class="text-body">{description}</p>
    </a>
</li>