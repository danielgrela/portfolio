---
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const miCorreo = "contacto@danielgrela.com";
---
<section id="Contacto" class="w-full wrap-break-word overflow-hidden text-start">
    <h2 class="text-2xl xl:text-3xl font-bold mb-4">{t('contacto.title')}</h2>
    <form id="formulario-contacto" class="gap-4 md:gap-6 flex flex-col mx-5">
        <div class="md:gap-1 flex flex-col">
            <label for="nombre" class="block text-sm font-medium text-heading mb-1">
            {t('contacto.form.nombre.title')}
            </label>
            <input 
            type="text" 
            id="nombre" 
            required
            class="text-md font-semibold w-full px-4 py-2 border border-gray-300 dark:border-gray-800 rounded-[10px] bg-gray-100 dark:bg-gray-900 text-heading focus:ring-1 focus:ring-gray-400 focus:outline-none transition-shadow duration-200"
            placeholder={t('contacto.form.nombre.placeholder')}
            />
        </div>
        <div class="md:gap-1 flex flex-col">
            <label for="asunto" class="block text-sm font-medium text-heading mb-1">
            {t('contacto.form.asunto.title')}
            </label>
            <input 
            type="text" 
            id="asunto" 
            required
            class="text-md font-semibold w-full px-4 py-2 border border-gray-300 dark:border-gray-800 rounded-[10px] bg-gray-100 dark:bg-gray-900 text-heading focus:ring-1 focus:ring-gray-400 focus:outline-none transition-shadow duration-200"
            placeholder={t('contacto.form.asunto.placeholder')}
            />
        </div>

        <div class="md:gap-1 flex flex-col">
            <label for="mensaje" class="block text-sm font-medium text-heading mb-1">
            {t('contacto.form.mensaje.title')}
            </label>
            <textarea 
            id="mensaje" 
            rows="5" 
            required
            class="text-md w-full px-4 py-2 border border-gray-300 dark:border-gray-800 rounded-[10px] bg-gray-100 dark:bg-gray-900 resize-y text-heading focus:ring-1 focus:ring-gray-400 focus:outline-none transition-shadow duration-200"
            placeholder={t('contacto.form.mensaje.placeholder')}
            ></textarea>
        </div>

        <button 
            type="submit" 
            class="w-fit cursor-pointer text-sm font-semibold text-heading py-3 px-5 rounded-md border 
            border-gray-300 dark:border-gray-800 hover:dark:border-gray-900 bg-gray-100 dark:bg-gray-900 hover:bg-gray-300 hover:dark:bg-gray-800"
        >
            {t('contacto.form.submit')}
        </button>
    </form>
</section>

<script define:vars={{ miCorreo }}>
  const formulario = document.getElementById('formulario-contacto');

  if (formulario) {
    formulario.addEventListener('submit', (evento) => {
      evento.preventDefault();
      const nombre = document.getElementById('nombre').value;
      const asunto = document.getElementById('asunto').value;
      const asuntoEnviar = `${nombre} - ${asunto}`;
      const mensaje = document.getElementById('mensaje').value;
      const enlaceMailto = `mailto:${miCorreo}?subject=${encodeURIComponent(asuntoEnviar)}&body=${encodeURIComponent(mensaje)}`;
      window.location.href = enlaceMailto;
    });
  }
</script>